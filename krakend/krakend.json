{
  "version": 3,
  "timeout": "30s",
  "cache_ttl": "300s",
  "name": "SmartLogix API Gateway",
  "port": 8080,
  "extra_config": {
    "github_com/devopsfaith/krakend-gologging": {
      "level": "DEBUG",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true,
      "format": "default"
    },
    "github_com/devopsfaith/krakend-cors": {
      "allow_origins": [
        "http://localhost:5173",
        "http://localhost:30080",
        "http://localhost:8080",
        "http://smartlogix.local"
      ],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allow_headers": ["Content-Type", "Authorization", "Accept"],
      "expose_headers": ["Content-Length", "Authorization"],
      "max_age": "3600"
    }
  },
